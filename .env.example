# ================================================================
# .env.example - Copia este archivo como ".env" y rellena los valores.
# NUNCA subas el archivo .env a GitHub.
# ================================================================

# Base API URL (backend principal)
REACT_APP_API_BASE_URL=https://tu-api.ejemplo.com/api

# Quotations API
REACT_APP_API_BASE_QUOTATIONS_URL=https://tu-api.ejemplo.com/api

# Client Process API
REACT_APP_API_BASE_CLIENTPROCESS_URL=https://tu-api.ejemplo.com/api

# Company Process API
REACT_APP_API_BASE_COMPANYPROCESS_URL=https://tu-api.ejemplo.com/api

# Client Form API
REACT_APP_API_BASE_CLIENTFORM_URL=https://tu-api.ejemplo.com/api

# n8n Webhooks (reemplaza con tu instancia de n8n)
REACT_APP_N8N_WEBHOOK_CLIENT=https://tu-n8n.ejemplo.com/webhook/client-form-completed
REACT_APP_N8N_WEBHOOK_FORM=https://tu-n8n.ejemplo.com/webhook/calendly-appointments/webhook
REACT_APP_N8N_WEBHOOK_CALENDLY=https://tu-n8n.ejemplo.com/webhook/calendly-scheduled
