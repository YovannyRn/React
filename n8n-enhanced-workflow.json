        "fromEmail": "yovanny.dev@gmail.com",
        "toEmail": "={{ $('Webhook: Detailed Form').item.json.body.email }}",
        "subject": "=🚀 {{ $('Webhook: Detailed Form').item.json.body.nombre }}, tu propuesta personalizada está lista",
        "emailFormat": "html",
        "html": "=<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Tu Propuesta Personalizada - MediCore</title>\n    <style>\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        body { font-family: 'Arial', sans-serif; line-height: 1.6; color: #333; background-color: #f8f9fa; }\n        .email-container { max-width: 600px; margin: 0 auto; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 20px; }\n        .email-content { background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.2); }\n        .header { background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white; padding: 30px 20px; text-align: center; }\n        .header h1 { font-size: 24px; margin-bottom: 10px; font-weight: bold; }\n        .header p { font-size: 16px; opacity: 0.9; }\n        .ai-message { background: #e3f2fd; padding: 25px; border-left: 4px solid #2196f3; margin: 20px; border-radius: 10px; }\n        .ai-message h3 { color: #1976d2; margin-bottom: 15px; }\n        .ai-message p { font-size: 16px; line-height: 1.8; }\n        .client-summary { background: #f8f9fa; padding: 20px; margin: 20px; border-radius: 10px; }\n        .client-summary h3 { color: #333; margin-bottom: 15px; }\n        .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; }\n        .summary-item { background: white; padding: 15px; border-radius: 8px; border-left: 3px solid #28a745; }\n        .summary-item strong { color: #28a745; display: block; margin-bottom: 5px; font-size: 12px; text-transform: uppercase; }\n        .cta-section { background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%); padding: 40px 20px; text-align: center; color: white; }\n        .cta-section h2 { font-size: 26px; margin-bottom: 15px; }\n        .cta-section p { font-size: 18px; margin-bottom: 30px; opacity: 0.9; }\n        .cta-button { display: inline-block; background: white; color: #ff6b6b; padding: 18px 40px; text-decoration: none; border-radius: 50px; font-weight: bold; font-size: 18px; transition: all 0.3s ease; box-shadow: 0 5px 15px rgba(0,0,0,0.2); }\n        .footer { background: #333; color: white; padding: 30px 20px; text-align: center; }\n        .footer h4 { margin-bottom: 15px; color: #28a745; }\n        .contact-info { margin: 15px 0; }\n        .contact-info a { color: #28a745; text-decoration: none; }\n        @media (max-width: 600px) { .email-container { padding: 10px; } .summary-grid { grid-template-columns: 1fr; } }\n    </style>\n</head>\n<body>\n    <div class=\"email-container\">\n        <div class=\"email-content\">\n            <div class=\"header\">\n                <h1>🎯 Propuesta Personalizada Lista</h1>\n                <p>Hemos analizado tu proyecto con IA avanzada</p>\n            </div>\n            \n            <div class=\"ai-message\">\n                <h3>💬 Mensaje Personalizado de Nuestro Equipo</h3>\n                <p>{{ $('AI: Generate Personalized Message').item.json.choices[0].message.content }}</p>\n            </div>\n            \n            <div class=\"client-summary\">\n                <h3>📋 Resumen de tu Proyecto</h3>\n                <div class=\"summary-grid\">\n                    <div class=\"summary-item\">\n                        <strong>🏢 Empresa</strong>\n                        <span>{{ $('Webhook: Detailed Form').item.json.body.empresa }}</span>\n                    </div>\n                    <div class=\"summary-item\">\n                        <strong>⚙️ Servicio</strong>\n                        <span>{{ $('Webhook: Detailed Form').item.json.body.servicio_solicitado }}</span>\n                    </div>\n                    <div class=\"summary-item\">\n                        <strong>💰 Presupuesto</strong>\n                        <span>{{ $('Webhook: Detailed Form').item.json.body.presupuesto_estimado }}</span>\n                    </div>\n                    <div class=\"summary-item\">\n                        <strong>🏭 Tamaño</strong>\n                        <span>{{ $('Webhook: Detailed Form').item.json.body['tamaño_empresa'] }}</span>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"cta-section\">\n                <h2>🗓️ ¡Agenda tu Consulta Estratégica!</h2>\n                <p>30 minutos para crear la hoja de ruta perfecta para tu proyecto</p>\n                <a href=\"https://calendly.com/yovannyn30?prefill_email={{ $('Webhook: Detailed Form').item.json.body.email }}&prefill_name={{ $('Webhook: Detailed Form').item.json.body.nombre }}\" class=\"cta-button\">\n                    📅 Agendar Consulta GRATUITA\n                </a>\n                <div style=\"margin-top: 20px;\">\n                    <small style=\"opacity: 0.8;\">✅ Análisis técnico incluido • ✅ Propuesta detallada • ✅ Sin compromiso</small>\n                </div>\n            </div>\n            \n            <div class=\"footer\">\n                <h4>🚀 MediCore - Tecnología que Transforma</h4>\n                <div class=\"contact-info\">\n                    <p>📧 Email: <a href=\"mailto:hola@medicore.com\">hola@medicore.com</a></p>\n                    <p>🌐 Web: <a href=\"https://medicore.com\">www.medicore.com</a></p>\n                    <p>💬 ¿Preguntas? Responde este email directamente</p>\n                </div>\n            </div>\n        </div>\n    </div>\n</body>\n</html>",
        "options": {}
